function log(msg, type='info'){
  const el=document.getElementById('log');
  el.style.display='block';
  el.innerHTML+='<div class="'+type+'">'+msg+'</div>';
  el.scrollTop=el.scrollHeight;
}
function setProgress(pct){
  document.getElementById('progress').style.display='block';
  document.getElementById('progress-bar').style.width=pct+'%';
}

async function iniciar(){
  const cfg={
    apiKey:document.getElementById('apiKey').value.trim(),
    authDomain:document.getElementById('authDomain').value.trim(),
    projectId:document.getElementById('projectId').value.trim(),
    storageBucket:document.getElementById('storageBucket').value.trim(),
    messagingSenderId:document.getElementById('messagingSenderId').value.trim(),
    appId:document.getElementById('appId').value.trim()
  };

  if(!cfg.apiKey||!cfg.projectId){
    log('❌ Preencha pelo menos API Key e Project ID.','err');return;
  }

  const btn=document.getElementById('btn');
  btn.disabled=true;btn.textContent='⏳ Conectando ao Firebase…';

  try{
    // Initialize (avoid duplicate app error)
    let app;
    try{ app=firebase.app(); }catch(e){ app=firebase.initializeApp(cfg); }
    const db=firebase.firestore();

    log('🟢 Firebase conectado! Projeto: '+cfg.projectId,'ok');
    log('📋 Verificando coleção existente…','info');

    // Check if pedidos already has data
    const existing=await db.collection('pedidos').limit(1).get();
    if(!existing.empty){
      const ok=confirm('O Firebase já tem dados na coleção "pedidos".\n\nCancelar = manter os existentes e adicionar\nOK = limpar tudo e reimportar do zero');
      if(ok){
        log('🗑 Limpando coleção pedidos…','warn');
        const all=await db.collection('pedidos').get();
        const batch=db.batch();
        all.docs.forEach(d=>batch.delete(d.ref));
        await batch.commit();
        log('✅ Coleção limpa.','ok');
      }
    }

    log('📤 Importando '+PEDIDOS.length+' pedidos…','info');
    btn.textContent='⏳ Importando…';

    let count=0;
    // Use batches of 500 (Firestore limit)
    const BATCH_SIZE=400;
    for(let i=0;i<PEDIDOS.length;i+=BATCH_SIZE){
      const batch=db.batch();
      const chunk=PEDIDOS.slice(i,i+BATCH_SIZE);
      chunk.forEach(p=>{
        const ref=db.collection('pedidos').doc();
        batch.set(ref,p);
        count++;
      });
      await batch.commit();
      setProgress(Math.round((count/PEDIDOS.length)*100));
      log('  ✓ '+count+'/'+PEDIDOS.length+' pedidos enviados','ok');
    }

    setProgress(100);
    log('','info');
    log('🎉 Importação concluída! '+count+' pedidos no Firebase.','ok');

    // Save config to localStorage so the main app picks it up
    localStorage.setItem('bj_fbconfig',JSON.stringify(cfg));
    log('💾 Credenciais salvas — o app vai conectar automaticamente.','ok');

    document.getElementById('success').style.display='block';
    document.getElementById('success-msg').textContent=count+' pedidos importados com sucesso!';
    btn.textContent='✅ Concluído!';

  }catch(e){
    log('❌ Erro: '+e.message,'err');
    log('Verifique se o Firestore está criado em modo de teste no console Firebase.','warn');
    btn.disabled=false;btn.textContent='🚀 Tentar novamente';
  }
}

// Pre-fill from localStorage if config already saved
try{
  const cfg=JSON.parse(localStorage.getItem('bj_fbconfig')||'{}');
  ['apiKey','authDomain','projectId','storageBucket','messagingSenderId','appId'].forEach(k=>{
    if(cfg[k])document.getElementById(k).value=cfg[k];
  });
}catch{}
</script>

